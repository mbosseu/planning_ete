---
import { App } from '../components/App';
import '../styles/global.css';
---

<html lang="fr">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Boxing Center - Planning d'Été</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@500;700&display=swap" rel="stylesheet">
	</head>
	<body class="bg-dark-bg text-white min-h-screen print:bg-white font-sans relative">
		{/* Image de fond en filigrane (optionnel, simulée avec un dégradé radial pour l'effet) */}
		<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-dark-surface/50 to-dark-bg -z-10 pointer-events-none"></div>

		<div class="max-w-7xl mx-auto p-4 sm:p-6 lg:p-8 space-y-8 print:p-0 print:m-0 print:space-y-0 print:max-w-none">
			<header class="border-b border-dark-surface-header pb-6 print:hidden flex flex-col md:flex-row items-center justify-between gap-4">
				<h1 class="text-4xl md:text-5xl font-bold tracking-widest uppercase font-oswald text-white flex flex-col md:flex-row md:items-baseline gap-2">
					Boxing <span class="text-brand-gold border-t-2 md:border-t-0 md:border-b-2 border-brand-gold pt-1 md:pt-0">Center</span>
				</h1>
				<p class="text-brand-gold text-lg uppercase tracking-wider font-semibold font-oswald">Saison 2026 - 2027</p>
			</header>

			<main class="print:m-0 print:p-0">
				<App client:only="react" />
			</main>
		</div>
	</body>
</html>
